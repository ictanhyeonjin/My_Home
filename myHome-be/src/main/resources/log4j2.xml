<?xml version="1.0" encoding="UTF-8" ?>
<Configuration status="WARN" name="kgict myhome">
	<Properties>
		<Property name="log-path">logs</Property>
		<Property name="logfile-name">myhome</Property>
		<Property name="LOG_EXCEPTION_CONVERSION_WORD">%xwEx</Property>
		<Property name="LOG_LEVEL_PATTERN">%5p</Property>
	</Properties>

	<Appenders>
		<Console name="Console" target="SYSTEM_OUT">
			<PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} ${LOG_LEVEL_PATTERN} ${sys:PID} --- [%15.15t] %-40.40c{1.} : %m%n${sys:LOG_EXCEPTION_CONVERSION_WORD}"/>
		</Console>
		<RollingFile name="RollingFile" filePattern="${log-path}/${logfile-name}_%d{yyyy-MM-dd}.log">
			<PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} ${LOG_LEVEL_PATTERN} ${sys:PID} --- [%15.15t] %c : %m%n${sys:LOG_EXCEPTION_CONVERSION_WORD}" />
			<Policies>
				<TimeBasedTriggeringPolicy />
			</Policies>
			<DirectWriteRolloverStrategy/>
		</RollingFile>
	</Appenders>

	<Loggers>
		<Root level="ERROR">
			<AppenderRef ref="Console"/>
		</Root>
		<Logger name="org.springframework" level="INFO" additivity="false">
			<AppenderRef ref="Console"/>
			<AppenderRef ref="RollingFile"/>
		</Logger>
		<Logger name="com.zaxxer.hikari" level="INFO" additivity="false">
			<AppenderRef ref="Console"/>
			<AppenderRef ref="RollingFile"/>
		</Logger>
		<Logger name="com.kgict.myhome" level="DEBUG" additivity="false">
			<AppenderRef ref="Console"/>
			<AppenderRef ref="RollingFile"/>
		</Logger>
	</Loggers>
</Configuration>
